<!-- Hero Section -->
<div class="hero-section">
    <div class="container">
        <h1 class="display-4">Courier Handover System</h1>
        <p class="lead">Select a courier service to begin the handover process</p>
    </div>
</div>

<!-- Service Selection -->
<div class="container service-selection">
    <div class="card shadow-lg">
        <div class="card-body">
            <div class="text-center mb-4">
                <div class="service-icon">
                    <i class="fas fa-shipping-fast fa-2x text-primary"></i>
                </div>
                <h2>Select Courier Service</h2>
                <p class="text-muted">Choose the courier service for shipment handover</p>
            </div>

            <div class="row g-4">
                <!-- Daewoo Express -->
                <div class="col-md-4">
                    <a href="/courier/form?type=Daewoo" class="text-decoration-none">
                        <div class="courier-card daewoo text-center">
                            <i class="fas fa-truck icon"></i>
                            <h3>Daewoo Express</h3>
                        </div>
                    </a>
                </div>

                <!-- Trax -->
                <div class="col-md-4">
                    <a href="/courier/form?type=Trax" class="text-decoration-none">
                        <div class="courier-card trax text-center">
                            <i class="fas fa-truck-loading icon"></i>
                            <h3>Trax Logistics</h3>
                        </div>
                    </a>
                </div>

                <!-- PostEx -->
                <div class="col-md-4">
                    <a href="/courier/form?type=PostEx" class="text-decoration-none">
                        <div class="courier-card postex text-center">
                            <i class="fas fa-box icon"></i>
                            <h3>Postex Courier</h3>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="container mt-5">
    <div class="row g-4">
        <!-- Quick Scanning -->
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-qrcode fa-2x"></i>
                </div>
                <h4>Quick Scanning</h4>
                <p>Easily scan tracking numbers for fast handover process</p>
            </div>
        </div>

        <!-- Real-time Updates -->
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-clock fa-2x"></i>
                </div>
                <h4>Real-time Updates</h4>
                <p>Track handover status and courier pickups instantly</p>
            </div>
        </div>

        <!-- Secure Handover -->
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="fas fa-shield-alt fa-2x"></i>
                </div>
                <h4>Secure Handover</h4>
                <p>Verified process with flyer ID confirmation</p>
            </div>
        </div>
    </div>
</div>
