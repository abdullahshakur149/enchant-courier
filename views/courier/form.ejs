<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <div class="text-center mb-4">
                    <i class="fas fa-clipboard-list fa-3x text-primary mb-3"></i>
                    <h2 class="card-title">Submit Tracking Information</h2>
                    <p class="text-muted">Please enter the tracking details for <%= courierType %>
                    </p>
                </div>

                <form id="courierForm" class="needs-validation" novalidate>
                    <div class="mb-3">
                        <label for="trackingNumber" class="form-label">Tracking Number</label>
                        <input type="text" class="form-control" id="trackingNumber" required
                            onkeydown="if(event.key === 'Enter') { event.preventDefault(); form.dispatchEvent(new Event('submit')); }">
                    </div>
                    <input type="hidden" id="courierType" value="<%= courierType %>">
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-paper-plane me-2"></i>
                            Submit Tracking
                        </button>
                        <a href="/" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i>
                            Back to Home
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="/js/main.js" type="module"></script>