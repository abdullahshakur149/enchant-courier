<% if (title && title.trim() !=="" ) { %>
  <h2 class="mb-4 fw-bold">
    <%= title %>
  </h2>
  <% } %>
    <div id="orders-table-container" class="ss-orders-container"></div>
    <div id="pagination-container" class="pagination-container"></div>


    <!-- Tracking History Modal -->
    <%- include('./components/trackingModel.ejs') %>


      <%- include('./components/editmodel.ejs') %>

        <%- include('./components/remarksModel.ejs') %>

          <%- include('./components/remarksHistory.ejs') %>






            <!-- Custom Scripts -->
            <script src="/js/orders.js"></script>
            <script>
              document.addEventListener('DOMContentLoaded', function () {
                const orderType = '<%= path %>' === '/delivered-orders' ? 'delivered' : 'all';
                OrderManager.init(orderType);
              });
            </script>

            <!-- Remarks History Modal -->
            <%- include('./components/remarksHistory.ejs') %>

              <style>
                .remarks-badge {
                  display: inline-block;
                  padding: 0.25rem 0.5rem;
                  background-color: var(--gray-100);
                  border-radius: 0.25rem;
                  color: var(--gray-700);
                  transition: all 0.2s ease;
                }

                .remarks-badge:hover {
                  background-color: var(--gray-200);
                }

                #remarksHistoryModal .table th {
                  background-color: var(--gray-50);
                  font-weight: 600;
                }

                #remarksHistoryModal .table td {
                  vertical-align: middle;
                }
              </style>