<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enchant Admin - Courier Handover</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/index.css">
</head>

<body>
    <%- include('./components/navbar.ejs') %>


        <%- include('./components/herosection.ejs') %>

            <div class="tracking-container">
                <div class="tracking-header">
                    <div class="logo">
                        <i class="fas fa-truck-loading"></i>
                    </div>
                    <h2>Select Courier Service</h2>
                    <p class="subtitle">Choose the courier service for shipment handover</p>
                </div>

                <div class="courier-buttons">
                    <a href="/track/daewoo" class="tracking-btn fastex-btn">
                        <i class="fas fa-shipping-fast"></i>
                        <span>Daewoo Express</span>
                        <i class="fas fa-arrow-right"></i>
                    </a>

                    <a href="/track/trax" class="tracking-btn trax-btn">
                        <i class="fas fa-truck"></i>
                        <span>Trax Logistics</span>
                        <i class="fas fa-arrow-right"></i>
                    </a>

                    <a href="/track/postex" class="tracking-btn postex-btn">
                        <i class="fas fa-box"></i>
                        <span>Postex Courier</span>
                        <i class="fas fa-arrow-right"></i>
                    </a>
                </div>

                <div class="features">
                    <div class="feature">
                        <i class="fas fa-qrcode"></i>
                        <h3>Quick Scanning</h3>
                        <p>Easily scan tracking numbers for fast handover process</p>
                    </div>
                    <div class="feature">
                        <i class="fas fa-history"></i>
                        <h3>Real-time Updates</h3>
                        <p>Track handover status and courier pickups instantly</p>
                    </div>
                    <div class="feature">
                        <i class="fas fa-shield-alt"></i>
                        <h3>Secure Handover</h3>
                        <p>Verified process with flyer ID confirmation</p>
                    </div>
                </div>
            </div>

            <%- include('./components/footer.ejs') %>

                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>