<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Add Tracking - <%= courier.toUpperCase() %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/index.css">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>

<body>
    <%- include('./components/navbar.ejs') %>


        <%- include('./components/herosection.ejs') %>


            <div class="tracking-container">
                <div class="tracking-header">
                    <div class="logo">
                        <i class="fas fa-exchange-alt"></i>
                    </div>
                    <h2>
                        <%= courier.toUpperCase() %> Handover
                    </h2>
                    <p class="subtitle">Enter the shipment details before handing over to <%= courier.toUpperCase() %>
                            team
                    </p>
                </div>

                <div class="form-container">
                    <form id="trackingForm" method="post">
                        <div class="form-group">
                            <label class="form-label">Tracking Number</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-barcode"></i></span>
                                <input id="courier-trackingNumber" type="text" class="form-control"
                                    name="trackingNumber" autofocus autocomplete="off" required
                                    placeholder="Scan or enter tracking number">
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Flyer ID</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                                <input id="courier-flyerid" type="text" class="form-control" autocomplete="off"
                                    name="flyerId" required placeholder="Enter delivery flyer ID">
                            </div>
                        </div>

                        <input id="courier-type" type="hidden" name="courier" value="<%= courier %>">

                        <button type="submit" class="tracking-btn fastex-btn">
                            <i class="fas fa-hand-holding-box"></i>
                            <span>Confirm Handover</span>
                            <i class="fas fa-arrow-right"></i>
                        </button>
                    </form>
                </div>

                <div id="verify-result" class="result-container"></div>

                <div id="success-animation" class="success-animation" style="display: none;">
                    <div class="success-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <h3>Handover Confirmed!</h3>
                    <p class="success-message">Shipment has been registered for <%= courier.toUpperCase() %> pickup</p>
                </div>
            </div>

            <%- include('./components/footer.ejs') %>

                <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

                <script>
                    document.getElementById('trackingForm').addEventListener('submit', async function (e) {
                        const resultContainer = document.getElementById("verify-result");
                        const formContainer = document.querySelector('.form-container');
                        const successAnimation = document.getElementById('success-animation');
                        e.preventDefault();

                        // Clear any previous messages
                        resultContainer.innerHTML = '';

                        const form = this;
                        const trackingNumber = document.getElementById('courier-trackingNumber').value.trim();
                        const flyerNumber = document.getElementById('courier-flyerid').value.trim();
                        const courierType = document.getElementById('courier-type').value;

                        if (!trackingNumber || !flyerNumber) {
                            resultContainer.innerHTML = `
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-circle"></i>
                        Please fill in all fields.
                    </div>
                `;
                            return;
                        }

                        const data = {
                            trackingNumber,
                            flyerNumber,
                            courierType
                        };

                        try {
                            const response = await axios.post('/submit-order', data);

                            if (response.data.success) {
                                // Hide the form with animation
                                formContainer.style.opacity = '0';
                                formContainer.style.transform = 'translateY(-20px)';

                                // Show success animation
                                successAnimation.style.display = 'block';
                                // Trigger reflow
                                successAnimation.offsetHeight;
                                successAnimation.classList.add('show');

                                // Reset form
                                form.reset();

                                // After 2 seconds, hide success and show form
                                setTimeout(() => {
                                    // Hide success animation
                                    successAnimation.classList.remove('show');

                                    setTimeout(() => {
                                        successAnimation.style.display = 'none';
                                        // Show form again
                                        formContainer.style.opacity = '1';
                                        formContainer.style.transform = 'translateY(0)';
                                        document.getElementById('courier-trackingNumber').focus();
                                    }, 300); // Wait for fade out animation
                                }, 2000);
                            } else {
                                resultContainer.innerHTML = `
                        <div class="alert alert-danger">
                            <i class="fas fa-times-circle"></i>
                            ${response.data.message}
                        </div>
                    `;
                            }
                        } catch (error) {
                            console.error(error);
                            // Check if it's a response error with a message
                            if (error.response && error.response.data && error.response.data.message) {
                                resultContainer.innerHTML = `
                        <div class="alert alert-danger">
                            <i class="fas fa-times-circle"></i>
                            ${error.response.data.message}
                        </div>
                    `;
                            } else {
                                resultContainer.innerHTML = `
                        <div class="alert alert-danger">
                            <i class="fas fa-times-circle"></i>
                            Server error. Please try again later.
                        </div>
                    `;
                            }
                        }
                    });
                </script>
</body>

</html>