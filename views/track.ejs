<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Add Tracking - <%= courier.toUpperCase() %>
    </title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/admin.css" />
    <link rel="stylesheet" href="/css/verification.css" />


</head>

<body>
    <!-- Include the navbar with hideSearchBar parameter -->
    <%- include('./dashboard/components/navbar.ejs', { hideSearchBar: true }) %>

        <div class="main-content">
            <div class="card p-4 shadow">
                <div class="form-container">
                    <h4 class="text-center mb-3">Track <%= courier.toUpperCase() %>
                    </h4>
                    <form id="trackingForm" method="post">
                        <div class="mb-3">
                            <label class="form-label">Tracking Number</label>
                            <input id="courier-trackingNumber" type="text" class="form-control" name="trackingNumber"
                                autofocus autocomplete="off" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Flyer ID</label>
                            <input id="courier-flyerid" type="text" class="form-control" autocomplete="off"
                                name="flyerId" required>
                        </div>

                        <input id="courier-type" type="hidden" name="courier" value="<%= courier %>">

                        <button type="submit" class="btn btn-primary w-100">Submit</button>
                    </form>
                </div>
                <div id="verify-result" class="mt-3 text-center"></div>
                <div id="success-animation" class="success-animation">
                    <i class="bi bi-check-circle-fill"></i>
                    <p class="mt-2 text-success">Order added successfully!</p>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

        <script>
            document.getElementById('trackingForm').addEventListener('submit', async function (e) {
                const resultContainer = document.getElementById("verify-result");
                const formContainer = document.querySelector('.form-container');
                const successAnimation = document.getElementById('success-animation');
                e.preventDefault();

                // Clear any previous messages
                resultContainer.innerHTML = '';

                const form = this;
                const trackingNumber = document.getElementById('courier-trackingNumber').value.trim();
                const flyerNumber = document.getElementById('courier-flyerid').value.trim();
                const courierType = document.getElementById('courier-type').value;

                if (!trackingNumber || !flyerNumber) {
                    alert('Please fill in all fields.');
                    return;
                }

                const data = {
                    trackingNumber,
                    flyerNumber,
                    courierType
                };

                try {
                    const response = await axios.post('/submit-order', data);

                    if (response.data.success) {
                        // Hide the form with animation
                        formContainer.classList.add('hidden');

                        // Show success animation
                        successAnimation.style.display = 'block';

                        // Reset form
                        form.reset();

                        // After 2 seconds, show the form again
                        setTimeout(() => {
                            formContainer.classList.remove('hidden');
                            successAnimation.style.display = 'none';
                            document.getElementById('courier-trackingNumber').focus();
                        }, 2000);
                    } else {
                        resultContainer.innerHTML = `<span class="badge bg-danger">${response.data.message}</span>`;
                    }
                } catch (error) {
                    console.error(error);
                    // Check if it's a response error with a message
                    if (error.response && error.response.data && error.response.data.message) {
                        resultContainer.innerHTML = `<span class="badge bg-danger">${error.response.data.message}</span>`;
                    } else {
                        resultContainer.innerHTML = `<span class="badge bg-danger">Server error. Please try again later.</span>`;
                    }
                }
            });
        </script>
</body>

</html>