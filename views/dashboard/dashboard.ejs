<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <title>Enchant | Admin</title>
    <meta content="" name="description">
    <meta content="" name="keywords">

    <!-- Favicons -->
    <link href="/img/logo.png" rel="icon">

    <!-- Google Fonts -->
    <link href="https://fonts.gstatic.com" rel="preconnect">
    <link
        href="https://fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i|Nunito:300,300i,400,400i,600,600i,700,700i|Poppins:300,300i,400,400i,500,500i,600,600i,700,700i"
        rel="stylesheet">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Boxicons -->
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.1.0/css/boxicons.min.css" rel="stylesheet">

    <!-- Quill -->
    <link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.bubble.css" rel="stylesheet">

    <!-- Remixicon -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@2.5.0/fonts/remixicon.css" rel="stylesheet">

    <!-- Simple Datatables -->
    <link href="https://cdn.jsdelivr.net/npm/simple-datatables@3.1.0/dist/style.css" rel="stylesheet">


    <!-- Template Main CSS File -->
    <link href="css/admin.css" rel="stylesheet">


</head>

<body>

    <!--  ======= Header ======= -->
    <%- include('./components/navbar.ejs') %>

        <!-- sidebar -->
        <%- include('./components/sidebar.ejs') %>

            <main id="main" class="main">

                <div
                    class="welcome-message d-flex justify-content-center alert alert-light d-flex align-items-center shadow-sm">
                    <i class="bi bi-person-circle me-2 fs-5 text-primary"></i>
                    <span class="fw-semibold text-center">Welcome back, <strong>
                            <%= user.username %>
                        </strong>!</span>
                </div>


                <div class="pagetitle">
                    <h1>Dashboard</h1>
                    <nav>
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
                            <li class="breadcrumb-item active">Dashboard</li>
                        </ol>
                    </nav>
                </div><!-- End Page Title -->

                <section class="section dashboard">
                    <div class="row">
                        <!-- Active Orders Card -->
                        <div class="col-xxl-4 col-md-6">
                            <div class="card info-card sales-card">
                                <div class="card-body">
                                    <h5 class="card-title">Active Orders <span>| This Month</span></h5>
                                    <div class="d-flex align-items-center">
                                        <div
                                            class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-box"></i>
                                        </div>
                                        <div class="ps-3">
                                            <h6>
                                                <%= stats.dispatchedCount %>
                                            </h6>
                                            <span class="text-primary small pt-1 fw-bold">In Transit</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Completed Orders Card -->
                        <div class="col-xxl-4 col-md-6">
                            <div class="card info-card sales-card">
                                <div class="card-body">
                                    <h5 class="card-title">Completed Orders <span>| This Month</span></h5>
                                    <div class="d-flex align-items-center">
                                        <div
                                            class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-check-circle"></i>
                                        </div>
                                        <div class="ps-3">
                                            <h6>
                                                <%= stats.completedCount %>
                                            </h6>
                                            <span class="text-success small pt-1 fw-bold">Delivered</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Returned Orders Card -->
                        <div class="col-xxl-4 col-md-6">
                            <div class="card info-card sales-card">
                                <div class="card-body">
                                    <h5 class="card-title">Returned Orders <span>| This Month</span></h5>
                                    <div class="d-flex align-items-center">
                                        <div
                                            class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </div>
                                        <div class="ps-3">
                                            <h6>
                                                <%= stats.returnedCount %>
                                            </h6>
                                            <span class="text-warning small pt-1 fw-bold">Returned</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Order Status Distribution -->
                        <div class="col-xxl-6">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">Order Status Distribution</h5>
                                    <canvas id="orderStatusChart" style="max-height: 400px;"></canvas>
                                </div>
                            </div>
                        </div>

                        <!-- Courier Distribution -->
                        <div class="col-xxl-6">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">Courier Distribution</h5>
                                    <canvas id="courierDistributionChart" style="max-height: 400px;"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Recent Orders -->
                        <div class="col-12">
                            <div class="card recent-sales overflow-auto">
                                <div class="card-body">
                                    <h5 class="card-title">Recent Orders</h5>
                                    <table class="table table-borderless datatable">
                                        <thead>
                                            <tr>
                                                <th scope="col">Tracking Number</th>
                                                <th scope="col">Flyer ID</th>
                                                <th scope="col">Courier</th>
                                                <th scope="col">Customer</th>
                                                <th scope="col">Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% recentOrders.forEach(order=> { %>
                                                <tr>
                                                    <td>
                                                        <%= order.trackingNumber %>
                                                    </td>
                                                    <td>
                                                        <%= order.flyerId %>
                                                    </td>
                                                    <td>
                                                        <%= order.courierType %>
                                                    </td>
                                                    <td>
                                                        <%= order.productInfo?.CustomerName || 'N/A' %>
                                                    </td>
                                                    <td>
                                                        <span
                                                            class="badge bg-<%= order.trackingResponse?.status?.toLowerCase().includes('delivered') ? 'success' : 'primary' %>">
                                                            <%= order.trackingResponse?.status || 'In Transit' %>
                                                        </span>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>


            </main><!-- End #main -->

            <!-- Vendor JS Files -->
            <!-- Chart.js -->
            <script src="https://cdn.jsdelivr.net/npm/chart.js@3.7.0/dist/chart.min.js"></script>

            <!-- ApexCharts -->
            <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.29.0/dist/apexcharts.min.js"></script>

            <!-- Bootstrap (including Bootstrap Bundle) -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

            <!-- ECharts -->
            <script src="https://cdn.jsdelivr.net/npm/echarts@5.3.0/dist/echarts.min.js"></script>

            <!-- Quill -->
            <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>

            <!-- Template Main JS File -->
            <script src="js/admin.js"></script>

            <script>
                // Wait for DOM to be fully loaded
                document.addEventListener('DOMContentLoaded', function () {
                    // Check if Chart.js is loaded
                    if (typeof Chart === 'undefined') {
                        console.error('Chart.js is not loaded');
                        return;
                    }

                    // Order Status Distribution Chart
                    const statusCtx = document.getElementById('orderStatusChart');
                    if (statusCtx) {
                        new Chart(statusCtx.getContext('2d'), {
                            type: 'doughnut',
                            data: {
                                labels: ['Active', 'Completed', 'Returned'],
                                datasets: [{
                                    data: [
                                        <%= stats.dispatchedCount %>,
                                        <%= stats.completedCount %>,
                                        <%= stats.returnedCount %>
                                    ],
                                    backgroundColor: ['#4154f1', '#2eca6a', '#ff771d']
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: {
                                        position: 'bottom'
                                    }
                                }
                            }
                        });
                    }

                    // Courier Distribution Chart
                    const courierCtx = document.getElementById('courierDistributionChart');
                    if (courierCtx) {
                        new Chart(courierCtx.getContext('2d'), {
                            type: 'bar',
                            data: {
                                labels: ['PostEx', 'Daewoo', 'Trax'],
                                datasets: [{
                                    label: 'Orders by Courier',
                                    data: [
                                        <%= courierStats.postex %>,
                                        <%= courierStats.daewoo %>,
                                        <%= courierStats.trax %>
                                    ],
                                    backgroundColor: ['#4154f1', '#2eca6a', '#ff771d']
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: {
                                        display: false
                                    }
                                }
                            }
                        });
                    }
                });
            </script>

</body>

</html>