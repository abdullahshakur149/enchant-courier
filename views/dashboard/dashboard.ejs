<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <title>Enchant | Admin</title>
    <meta content="" name="description">
    <meta content="" name="keywords">

    <!-- Favicons -->
    <link href="/img/logo.png" rel="icon">

    <!-- Google Fonts -->
    <link href="https://fonts.gstatic.com" rel="preconnect">
    <link
        href="https://fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i|Nunito:300,300i,400,400i,600,600i,700,700i|Poppins:300,300i,400,400i,500,500i,600,600i,700,700i"
        rel="stylesheet">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Boxicons -->
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.1.0/css/boxicons.min.css" rel="stylesheet">

    <!-- Quill -->
    <link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.bubble.css" rel="stylesheet">

    <!-- Remixicon -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@2.5.0/fonts/remixicon.css" rel="stylesheet">

    <!-- Simple Datatables -->
    <link href="https://cdn.jsdelivr.net/npm/simple-datatables@3.1.0/dist/style.css" rel="stylesheet">


    <!-- Template Main CSS File -->
    <link href="css/admin.css" rel="stylesheet">


</head>

<body>

    <!--  ======= Header ======= -->
    <%- include('./components/navbar.ejs') %>

        <!-- sidebar -->
        <%- include('./components/sidebar.ejs') %>

            <main id="main" class="main">

                <div
                    class="welcome-message d-flex justify-content-center alert alert-light d-flex align-items-center shadow-sm">
                    <i class="bi bi-person-circle me-2 fs-5 text-primary"></i>
                    <span class="fw-semibold text-center">Welcome back, <strong>
                            <%= user.username %>
                        </strong>!</span>
                </div>


                <div class="pagetitle">
                    <h1>Dashboard</h1>
                    <nav>
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/dashboard">Home</a></li>
                            <li class="breadcrumb-item active">Dashboard</li>
                        </ol>
                    </nav>
                </div><!-- End Page Title -->

                <section class="section dashboard">
                    <!-- Overview Cards -->
                    <div class="row">
                        <div class="col-12">
                            <h5 class="card-title mb-3">Order Overview</h5>
                        </div>
                        <!-- Total Orders Card -->
                        <div class="col-xxl-3 col-md-6">
                            <div class="card info-card sales-card">
                                <div class="card-body">
                                    <h5 class="card-title">Total Orders</h5>
                                    <div class="d-flex align-items-center">
                                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-box-seam"></i>
                                        </div>
                                        <div class="ps-3">
                                            <h6><%= orderStats.total %></h6>
                                            <span class="text-primary small pt-1 fw-bold">All Time</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Delivered Orders Card -->
                        <div class="col-xxl-3 col-md-6">
                            <div class="card info-card sales-card">
                                <div class="card-body">
                                    <h5 class="card-title">Delivered Orders</h5>
                                    <div class="d-flex align-items-center">
                                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-check-circle"></i>
                                        </div>
                                        <div class="ps-3">
                                            <h6><%= orderStats.delivered %></h6>
                                            <span class="text-success small pt-1 fw-bold">All Time</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Returned Orders Card -->
                        <div class="col-xxl-3 col-md-6">
                            <div class="card info-card sales-card">
                                <div class="card-body">
                                    <h5 class="card-title">Returned Orders</h5>
                                    <div class="d-flex align-items-center">
                                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </div>
                                        <div class="ps-3">
                                            <h6><%= orderStats.returned %></h6>
                                            <span class="text-warning small pt-1 fw-bold">All Time</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Pending Orders Card -->
                        <div class="col-xxl-3 col-md-6">
                            <div class="card info-card sales-card">
                                <div class="card-body">
                                    <h5 class="card-title">Pending Orders</h5>
                                    <div class="d-flex align-items-center">
                                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-clock"></i>
                                        </div>
                                        <div class="ps-3">
                                            <h6><%= orderStats.pending %></h6>
                                            <span class="text-info small pt-1 fw-bold">All Time</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Performance Metrics -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <h5 class="card-title mb-3">Performance Metrics</h5>
                        </div>
                        <!-- Success Rate Card -->
                        <div class="col-xxl-4 col-md-6">
                            <div class="card info-card customers-card">
                                <div class="card-body">
                                    <h5 class="card-title">Success Rate</h5>
                                    <div class="d-flex align-items-center">
                                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-graph-up"></i>
                                        </div>
                                        <div class="ps-3">
                                            <h6><%= ((orderStats.delivered / orderStats.total) * 100 || 0).toFixed(1) %>%</h6>
                                            <span class="text-success small pt-1 fw-bold">Successful Deliveries</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Return Rate Card -->
                        <div class="col-xxl-4 col-md-6">
                            <div class="card info-card customers-card">
                                <div class="card-body">
                                    <h5 class="card-title">Return Rate</h5>
                                    <div class="d-flex align-items-center">
                                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-arrow-counterclockwise"></i>
                                        </div>
                                        <div class="ps-3">
                                            <h6><%= ((orderStats.returned / orderStats.total) * 100 || 0).toFixed(1) %>%</h6>
                                            <span class="text-warning small pt-1 fw-bold">Returned Orders</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Average Order Value Card -->
                        <div class="col-xxl-4 col-md-6">
                            <div class="card info-card sales-card">
                                <div class="card-body">
                                    <h5 class="card-title">Average Order Value</h5>
                                    <div class="d-flex align-items-center">
                                        <div class="card-icon rounded-circle d-flex align-items-center justify-content-center">
                                            <i class="bi bi-cart"></i>
                                        </div>
                                        <div class="ps-3">
                                            <h6>Rs. <%= (orderStats.delivered > 0 ? (orderStats.delivered * 1000 / orderStats.delivered) : 0).toLocaleString() %></h6>
                                            <span class="text-primary small pt-1 fw-bold">Per Delivered Order</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Charts Section -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <h5 class="card-title mb-3">Visual Analytics</h5>
                        </div>
                        <!-- Order Status Distribution -->
                        <div class="col-xxl-6">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">Order Status Distribution</h5>
                                    <canvas id="orderStatusChart" style="max-height: 400px;"></canvas>
                                </div>
                            </div>
                        </div>

                        <!-- Delivery Performance -->
                        <div class="col-xxl-6">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">Delivery Performance</h5>
                                    <canvas id="deliveryPerformanceChart" style="max-height: 400px;"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Recent Orders Section -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <h5 class="card-title mb-3">Recent Orders</h5>
                        </div>
                        <div class="col-12">
                            <div class="card recent-sales overflow-auto">
                                <div class="card-body">
                                    <table class="table table-borderless datatable">
                                        <thead>
                                            <tr>
                                                <th scope="col">Tracking #</th>
                                                <th scope="col">Courier</th>
                                                <th scope="col">Customer</th>
                                                <th scope="col">Status</th>
                                                <th scope="col">Last Update</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% recentOrders.forEach(order => { %>
                                                <tr>
                                                    <td>
                                                        <a href="/dashboard/orders/<%= order._id %>">
                                                            <%= order.trackingNumber %>
                                                        </a>
                                                    </td>
                                                    <td><%= order.courierType %></td>
                                                    <td><%= order.customer_name || 'N/A' %></td>
                                                    <td>
                                                        <% if (order.isDelivered) { %>
                                                            <span class="badge bg-success">Delivered</span>
                                                        <% } else if (order.isReturned) { %>
                                                            <span class="badge bg-warning">Returned</span>
                                                        <% } else { %>
                                                            <span class="badge bg-primary">
                                                                <%= order.latestStatus || 'In Progress' %>
                                                            </span>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <%= order.last_tracking_update ? new Date(order.last_tracking_update).toLocaleString() : 'N/A' %>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>


            </main><!-- End #main -->

            <!-- Vendor JS Files -->
            <!-- Chart.js -->
            <script src="https://cdn.jsdelivr.net/npm/chart.js@3.7.0/dist/chart.min.js"></script>

            <!-- ApexCharts -->
            <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.29.0/dist/apexcharts.min.js"></script>

            <!-- Bootstrap (including Bootstrap Bundle) -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

            <!-- ECharts -->
            <script src="https://cdn.jsdelivr.net/npm/echarts@5.3.0/dist/echarts.min.js"></script>

            <!-- Quill -->
            <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>

            <!-- Template Main JS File -->
            <script src="js/admin.js"></script>

            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    // Order Status Distribution Chart
                    const statusCtx = document.getElementById('orderStatusChart');
                    if (statusCtx) {
                        new Chart(statusCtx.getContext('2d'), {
                            type: 'doughnut',
                            data: {
                                labels: ['Pending', 'Delivered', 'Returned'],
                                datasets: [{
                                    data: [
                                        <%= orderStats.pending %>,
                                        <%= orderStats.delivered %>,
                                        <%= orderStats.returned %>
                                    ],
                                    backgroundColor: [
                                        'rgba(54, 162, 235, 0.8)',
                                        'rgba(75, 192, 192, 0.8)',
                                        'rgba(255, 206, 86, 0.8)'
                                    ]
                                }]
                            },
                            options: {
                                responsive: true,
                                plugins: {
                                    legend: {
                                        position: 'bottom'
                                    }
                                }
                            }
                        });
                    }

                    // Delivery Performance Chart
                    const performanceCtx = document.getElementById('deliveryPerformanceChart');
                    if (performanceCtx) {
                        new Chart(performanceCtx.getContext('2d'), {
                            type: 'bar',
                            data: {
                                labels: ['Orders'],
                                datasets: [{
                                    label: 'Delivered',
                                    data: [<%= orderStats.delivered %>],
                                    backgroundColor: 'rgba(75, 192, 192, 0.8)'
                                }, {
                                    label: 'Returned',
                                    data: [<%= orderStats.returned %>],
                                    backgroundColor: 'rgba(255, 206, 86, 0.8)'
                                }, {
                                    label: 'Pending',
                                    data: [<%= orderStats.pending %>],
                                    backgroundColor: 'rgba(54, 162, 235, 0.8)'
                                }]
                            },
                            options: {
                                responsive: true,
                                plugins: {
                                    legend: {
                                        position: 'bottom'
                                    }
                                },
                                scales: {
                                    y: {
                                        beginAtZero: true
                                    }
                                }
                            }
                        });
                    }
                });
            </script>

            <style>
                .table-hover tbody tr:hover {
                    background-color: rgba(0, 0, 0, 0.02);
                }

                .badge {
                    padding: 0.5em 0.75em;
                    font-weight: 500;
                    letter-spacing: 0.5px;
                    white-space: nowrap;
                }

                .badge i {
                    font-size: 0.9em;
                }

                .btn-sm {
                    padding: 0.25rem 0.5rem;
                    font-size: 0.875rem;
                }

                .btn i {
                    font-size: 0.9em;
                }

                th {
                    white-space: nowrap;
                }

                .customers-card .card-icon {
                    background-color: rgba(255, 193, 7, 0.2);
                    color: #ffc107;
                }
            </style>

</body>

</html>