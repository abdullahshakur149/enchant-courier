<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

    <link href="/css/admin.css" rel="stylesheet">

    <!-- Toastify CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.8.4/axios.min.js"
        integrity="sha512-2A1+/TAny5loNGk3RBbk11FwoKXYOMfAK6R7r4CpQH7Luz4pezqEGcfphoNzB7SM4dixUoJsKkBsB6kg+dNE2g=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>

</head>

<body>

    <%- include('./components/navbar.ejs') %>

        <%- include('./components/sidebar.ejs') %>


            <main id="main" class="main">

                <div class="container text-center mt-5 my-4">
                    <div class="card shadow-sm" style="max-width: 400px; margin: auto;">
                        <div class="card-body">
                            <h5 class="card-title text-center mb-3">Verify Returned Orders</h5>
                            <form id="verify-return-form">
                                <div class="mb-2">
                                    <label for="courier-trackingNumber" class="form-label">Tracking Number</label>
                                    <input type="text" class="form-control form-control-sm" id="courier-trackingNumber"
                                        name="courier-trackingNumber" required>
                                </div>
                                <div class="mb-2">
                                    <label for="courier-flyerid" class="form-label">Flyer ID</label>
                                    <input type="text" class="form-control form-control-sm" id="courier-flyerid"
                                        name="courier-flyerid" required>
                                </div>
                                <button type="submit" class="btn btn-primary btn-sm w-100">Verify</button>
                            </form>
                            <div id="verify-result" class="mt-3 text-center"></div>

                        </div>
                    </div>
                </div>

            </main><!-- End #main -->



            <script src="/js/admin.js"></script>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

            <script>
                document.getElementById('verify-return-form').addEventListener('submit', async function (e) {
                    e.preventDefault();

                    const form = this;
                    const trackingNumber = document.getElementById('courier-trackingNumber').value.trim();
                    const flyerNumber = document.getElementById('courier-flyerid').value.trim();
                    const resultContainer = document.getElementById('verify-result');

                    if (!trackingNumber || !flyerNumber) {
                        alert('Please fill in all fields.');
                        return;
                    }

                    const data = {
                        trackingNumber,
                        flyNumber: flyerNumber,
                    };

                    try {
                        const response = await axios.post('/verify/verify-return', data);

                        if (response.data.success) {
                            resultContainer.innerHTML = `<span class="badge bg-success">${response.data.message}</span>`;
                            form.reset();
                        } else {
                            resultContainer.innerHTML = `<span class="badge bg-danger">${response.data.message}</span>`;
                        }
                    } catch (error) {
                        console.error(error);
                        resultContainer.innerHTML = `<span class="badge bg-danger">${error.response?.data?.message || "Server error"}</span>`;
                    }
                });
            </script>





</body>

</html>