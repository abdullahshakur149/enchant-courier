<div class="row g-4 mb-4">
    <!-- Total Orders & Pending Orders -->
    <div class="col-md-6">
        <div class="card h-100 shadow-lg border-0 rounded-3" style="background: linear-gradient(135deg, #2563eb, #3b82f6);">
            <div class="card-body d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="card-title text-white mb-0 text-xl font-weight-bold">Total Orders</h5>
                    <i class="fas fa-box text-white fa-3x"></i>
                </div>
                <h2 class="text-white mb-0 text-5xl font-weight-bold"><%= totalOrders %></h2>
                <p class="text-white-50 mb-0 text-sm">Total number of orders</p>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100 shadow-lg border-0 rounded-3" style="background: linear-gradient(135deg, #ffb74d, #ffa000);">
            <div class="card-body d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="card-title text-white mb-0 text-xl font-weight-bold">Pending Orders</h5>
                    <i class="fas fa-clock text-white fa-3x"></i>
                </div>
                <h2 class="text-white mb-0 text-5xl font-weight-bold"><%= pendingOrders %></h2>
                <p class="text-white-50 mb-0 text-sm">Orders awaiting processing</p>
            </div>
        </div>
    </div>

    <!-- Delivered Orders & Returned Orders -->
    <div class="col-md-6">
        <div class="card h-100 shadow-lg border-0 rounded-3" style="background: linear-gradient(135deg, #4caf50, #81c784);">
            <div class="card-body d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="card-title text-white mb-0 text-xl font-weight-bold">Delivered Orders</h5>
                    <i class="fas fa-check-circle text-white fa-3x"></i>
                </div>
                <h2 class="text-white mb-0 text-5xl font-weight-bold"><%= deliveredOrders %></h2>
                <p class="text-white-50 mb-0 text-sm">Orders successfully delivered</p>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100 shadow-lg border-0 rounded-3" style="background: linear-gradient(135deg, #f44336, #ef5350);">
            <div class="card-body d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="card-title text-white mb-0 text-xl font-weight-bold">Returned Orders</h5>
                    <i class="fas fa-undo text-white fa-3x"></i>
                </div>
                <h2 class="text-white mb-0 text-5xl font-weight-bold"><%= returnedOrders %></h2>
                <p class="text-white-50 mb-0 text-sm">Returned items</p>
            </div>
        </div>
    </div>

    <!-- New Cards for Today's Data -->
    <div class="col-md-6">
        <div class="card h-100 shadow-lg border-0 rounded-3" style="background: linear-gradient(135deg, #00bcd4, #26c6da);">
            <div class="card-body d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="card-title text-white mb-0 text-xl font-weight-bold">Orders Created Today</h5>
                    <i class="fas fa-calendar-plus text-white fa-3x"></i>
                </div>
                <h2 class="text-white mb-0 text-5xl font-weight-bold"><%= totalOrdersToday %></h2>
                <p class="text-white-50 mb-0 text-sm">Orders created today</p>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100 shadow-lg border-0 rounded-3" style="background: linear-gradient(135deg, #8e24aa, #d81b60);">
            <div class="card-body d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="card-title text-white mb-0 text-xl font-weight-bold">Orders Delivered Today</h5>
                    <i class="fas fa-truck-loading text-white fa-3x"></i>
                </div>
                <h2 class="text-white mb-0 text-5xl font-weight-bold"><%= deliveredOrdersToday %></h2>
                <p class="text-white-50 mb-0 text-sm">Orders delivered today</p>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100 shadow-lg border-0 rounded-3" style="background: linear-gradient(135deg, #ff4081, #f50057);">
            <div class="card-body d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="card-title text-white mb-0 text-xl font-weight-bold">Orders Returned Today</h5>
                    <i class="fas fa-undo-alt text-white fa-3x"></i>
                </div>
                <h2 class="text-white mb-0 text-5xl font-weight-bold"><%= returnedOrdersToday %></h2>
                <p class="text-white-50 mb-0 text-sm">Orders returned today</p>
            </div>
        </div>
    </div>
</div>

<!-- Add custom hover effects and animations -->
<style>
    .card:hover {
        transform: translateY(-10px);
        transition: transform 0.3s ease-in-out;
    }

    .card i {
        transition: transform 0.3s ease-in-out;
    }

    .card:hover i {
        transform: scale(1.3);
    }

    .card-body {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
</style>
