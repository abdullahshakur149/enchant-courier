<!-- Dashboard Content -->
<div class="container-fluid py-4">
  <!-- Quick Actions Section -->
  <div class="quick-actions mb-4">
    <div class="section-header d-flex justify-content-between align-items-center mb-3">
      <h2 class="section-title h4 mb-0">Quick Actions</h2>
    </div>
    <div class="actions-grid">
      <a href="/dashboard/orders/new" class="action-card bg-primary bg-opacity-10 hover-shadow">
        <div class="action-icon text-primary">
          <i class="fas fa-plus-circle fa-2x"></i>
        </div>
        <div class="action-text fw-medium">New Order</div>
      </a>
      <a href="/dashboard/orders" class="action-card bg-info bg-opacity-10 hover-shadow">
        <div class="action-icon text-info">
          <i class="fas fa-list fa-2x"></i>
        </div>
        <div class="action-text fw-medium">View Orders</div>
      </a>
      <a href="/dashboard/delivered-orders" class="action-card bg-success bg-opacity-10 hover-shadow">
        <div class="action-icon text-success">
          <i class="fas fa-check-double fa-2x"></i>
        </div>
        <div class="action-text fw-medium">Delivered Orders</div>
      </a>
      <a href="/dashboard/returned-orders" class="action-card bg-warning bg-opacity-10 hover-shadow">
        <div class="action-icon text-warning">
          <i class="fas fa-undo fa-2x"></i>
        </div>
        <div class="action-text fw-medium">Returned Orders</div>
      </a>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="dashboard-stats row g-3 mb-4">
    <!-- Total Orders Card -->
    <div class="col-md-6 col-lg-3">
      <div class="stat-card total-orders rounded-4 p-3 bg-white shadow-sm">
        <div class="d-flex align-items-center mb-2">
          <div class="stat-icon bg-primary bg-opacity-10 rounded-3 p-2 me-3">
            <i class="fas fa-shopping-cart text-primary"></i>
          </div>
          <div class="stat-label text-muted">Total Orders</div>
        </div>
        <div class="stat-value h3 mb-1"><%= totalOrders %></div>
        <div class="stat-change small text-muted">
          <span>Today: <%= totalOrdersToday %></span>
        </div>
      </div>
    </div>

    <!-- Delivered Orders Card -->
    <div class="col-md-6 col-lg-3">
      <div class="stat-card delivered rounded-4 p-3 bg-white shadow-sm">
        <div class="d-flex align-items-center mb-2">
          <div class="stat-icon bg-success bg-opacity-10 rounded-3 p-2 me-3">
            <i class="fas fa-check-circle text-success"></i>
          </div>
          <div class="stat-label text-muted">Delivered Orders</div>
        </div>
        <div class="stat-value h3 mb-1"><%= deliveredOrders %></div>
        <div class="stat-change small text-success">
          <span>Today: <%= deliveredOrdersToday %></span>
        </div>
      </div>
    </div>

    <!-- Returned Orders Card -->
    <div class="col-md-6 col-lg-3">
      <div class="stat-card returned rounded-4 p-3 bg-white shadow-sm">
        <div class="d-flex align-items-center mb-2">
          <div class="stat-icon bg-warning bg-opacity-10 rounded-3 p-2 me-3">
            <i class="fas fa-undo text-warning"></i>
          </div>
          <div class="stat-label text-muted">Returned Orders</div>
        </div>
        <div class="stat-value h3 mb-1"><%= returnedOrders %></div>
        <div class="stat-change small text-warning">
          <span>Today: <%= returnedOrdersToday %></span>
        </div>
      </div>
    </div>

    <!-- Pending Orders Card -->
    <div class="col-md-6 col-lg-3">
      <div class="stat-card pending rounded-4 p-3 bg-white shadow-sm">
        <div class="d-flex align-items-center mb-2">
          <div class="stat-icon bg-info bg-opacity-10 rounded-3 p-2 me-3">
            <i class="fas fa-clock text-info"></i>
          </div>
          <div class="stat-label text-muted">Pending Orders</div>
        </div>
        <div class="stat-value h3 mb-1"><%= pendingOrders %></div>
        <div class="stat-change small text-muted">
          <span>Awaiting Delivery</span>
        </div>
      </div>
    </div>

    <% 
      const courierTypes = ['Trax', 'Postex', 'Daewoo'];
      courierTypes.forEach(type => {
        const courierData = deliveredByCourierToday.find(c => c.courierType === type) || { count: 0, courierType: type };
    %>
      <div class="col-md-6 col-lg-3">
        <div class="stat-card courier rounded-4 p-3 bg-white shadow-sm">
          <div class="d-flex align-items-center mb-2">
            <div class="stat-icon bg-brown bg-opacity-10 rounded-3 p-2 me-3">
              <i class="fas fa-truck text-brown"></i>
            </div>
            <div class="stat-label text-muted">Delivered Today</div>
          </div>
          <div class="stat-value h3 mb-1"><%= courierData.count %></div>
          <div class="stat-change small text-muted">
            <span><%= courierData.courierType %></span>
          </div>
        </div>
      </div>
    <% }); %>
  </div>

  <!-- Charts Section -->
  <div class="row g-4 mb-4">
    <div class="col-md-6">
      <div class="chart-card bg-white rounded-4 p-4 shadow-sm">
        <div class="section-header d-flex justify-content-between align-items-center mb-4">
          <h2 class="section-title h5 mb-0">Orders Overview</h2>
          <div class="chart-actions">
            <select class="form-select form-select-sm border-0 bg-light" id="ordersTimeRange">
              <option value="7">Last 7 Days</option>
              <option value="30">Last 30 Days</option>
              <option value="90">Last 90 Days</option>
            </select>
          </div>
        </div>
        <div style="height: 300px;">
          <canvas id="ordersChart"></canvas>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="chart-card bg-white rounded-4 p-4 shadow-sm">
        <div class="section-header mb-4">
          <h2 class="section-title h5 mb-0">Courier Distribution</h2>
        </div>
        <div style="height: 300px;">
          <canvas id="courierChart"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Latest Orders Section -->
  <div class="latest-orders bg-white rounded-4 p-4 shadow-sm">
    <div class="section-header d-flex justify-content-between align-items-center mb-4">
      <h2 class="section-title h5 mb-0">Latest Orders</h2>
      <a href="/dashboard/orders" class="btn btn-sm btn-outline-primary">
        View All Orders <i class="fas fa-arrow-right ms-1"></i>
      </a>
    </div>
    
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="bg-light">
          <tr>
            <th class="border-0">Order ID</th>
            <th class="border-0">Customer</th>
            <th class="border-0">Date</th>
            <th class="border-0">Status</th>
            <th class="border-0">Amount</th>
          </tr>
        </thead>
        <tbody>
          <% latestOrders.forEach(order => { %>
            <tr>
              <td class="fw-medium">#<%= order.trackingNumber %></td>
              <td><%= order.productInfo?.CustomerName || 'N/A' %></td>
              <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
              <td>
                <% if (order.isDelivered) { %>
                  <span class="badge bg-success bg-opacity-10 text-success">Delivered</span>
                <% } else if (order.isReturned) { %>
                  <span class="badge bg-warning bg-opacity-10 text-warning">Returned</span>
                <% } else { %>
                  <span class="badge bg-info bg-opacity-10 text-info">Pending</span>
                <% } %>
              </td>
              <td class="fw-medium">Rs. <%= order.invoicePayment || '0' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>



<!-- Include Chart.js -->



<!-- Dashboard Scripts -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Common chart options
  const commonOptions = {
    responsive: true,
    maintainAspectRatio: false,
    animation: {
      duration: 1000
    },
    interaction: {
      mode: 'index',
      intersect: false
    },
    elements: {
      point: {
        radius: 3,
        hoverRadius: 5,
        hoverBorderWidth: 2
      },
      line: {
        borderWidth: 2,
        tension: 0.4
      }
    }
  };

  // Orders Chart
  const ordersCtx = document.getElementById('ordersChart').getContext('2d');
  new Chart(ordersCtx, {
    type: 'line',
    data: {
      labels: <%- JSON.stringify(chartData.ordersByDay.labels) %>,
      datasets: [{
        label: 'New Orders',
        data: <%- JSON.stringify(chartData.ordersByDay.data) %>,
        borderColor: '#2563eb',
        backgroundColor: 'rgba(37, 99, 235, 0.1)',
        fill: true,
        tension: 0.4
      }]
    },
    options: {
      ...commonOptions,
      plugins: {
        legend: {
          display: false
        },
        tooltip: {
          mode: 'index',
          intersect: false,
          backgroundColor: 'rgba(0, 0, 0, 0.8)',
          padding: 10,
          titleFont: {
            size: 14,
            weight: 'bold'
          },
          bodyFont: {
            size: 13
          },
          callbacks: {
            label: function(context) {
              return `Orders: ${context.parsed.y}`;
            }
          }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          grid: {
            display: true,
            drawBorder: false,
            color: 'rgba(0, 0, 0, 0.05)'
          },
          ticks: {
            precision: 0,
            font: {
              size: 12
            }
          }
        },
        x: {
          grid: {
            display: false
          },
          ticks: {
            font: {
              size: 12
            }
          }
        }
      }
    }
  });

  // Courier Distribution Chart
  const courierCtx = document.getElementById('courierChart').getContext('2d');
  new Chart(courierCtx, {
    type: 'doughnut',
    data: {
      labels: <%- JSON.stringify(chartData.courierDistribution.labels) %>,
      datasets: [{
        data: <%- JSON.stringify(chartData.courierDistribution.data) %>,
        backgroundColor: [
          '#059669', // Postex color
          '#2563eb', // Daewoo color
          '#64748b', // Trax color
          '#94a3b8'  // Unknown color
        ],
        borderWidth: 2,
        hoverOffset: 4
      }]
    },
    options: {
      ...commonOptions,
      cutout: '60%',
      plugins: {
        legend: {
          position: 'bottom',
          labels: {
            padding: 20,
            usePointStyle: true,
            font: {
              size: 12
            }
          }
        },
        tooltip: {
          backgroundColor: 'rgba(0, 0, 0, 0.8)',
          padding: 10,
          titleFont: {
            size: 14,
            weight: 'bold'
          },
          bodyFont: {
            size: 13
          },
          callbacks: {
            label: function(context) {
              const label = context.label || '';
              const value = context.parsed || 0;
              const total = context.dataset.data.reduce((a, b) => a + b, 0);
              const percentage = Math.round((value / total) * 100);
              return `${label}: ${value} (${percentage}%)`;
            }
          }
        }
      }
    }
  });

  // Time range selector handler
  document.getElementById('ordersTimeRange').addEventListener('change', function(e) {
    // Here you would typically make an AJAX call to fetch new data
    console.log('Selected time range:', e.target.value);
  });
});
</script>
