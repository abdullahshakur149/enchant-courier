<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Order Details</h4>
    <div>
        <input type="text" id="searchInput" class="form-control d-inline-block" placeholder="Search..."
            style="width: 200px;">
        <button class="btn btn-primary ms-2" onclick="exportTableToCSV('orders.csv')">
            <i class="bi bi-download"></i> Export
        </button>
    </div>
</div>
<!-- change -->
<!-- Order Table -->
<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th hidden>id</th>
            <th>#</th>
            <th>Tracking Number</th>
            <th>Flyer ID</th>
            <th>Courier Type</th>
            <th>Date</th>
            <th>Customer Name</th>
            <th>Address</th>
            <th>Product Name</th>
            <th>Quantity</th>
            <th>Transaction Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody id="orderTable">
        <% if (trackingData.length===0) { %>
            <tr>
                <td colspan="6" class="text-center">No orders found</td>
            </tr>
            <% } else { %>
                <% trackingData.forEach((order, index)=> {
                    let status = 'N/A';
                    if (order.courierType.toLowerCase() === 'postex') {
                    status = order.trackingResponse?.status || 'N/A';
                    } else if (order.courierType.toLowerCase() === 'daewoo' || order.courierType.toLowerCase() ===
                    'trax') {
                    status = order.trackingResponse?.status || 'N/A';
                    }
                    const productInfo = order.productInfo || {};
                    %>
                    <tr data-id="<%= order._id %>" data-tracking-number="<%= order.trackingNumber %>"
                        data-flyer-id="<%= order.flyerId || 'N/A' %>"
                        data-courier-type="<%= order.courierType || 'N/A' %>" data-status="<%= status %>">
                    <tr data-id="<%= order._id %>" data-tracking-number="<%= order.trackingNumber %>"
                        data-flyer-id="<%= order.flyerId || 'N/A' %>"
                        data-courier-type="<%= order.courierType || 'N/A' %>" data-status="<%= status %>">
                        <td>
                            <%= index + 1 %>
                        </td>
                        <td>
                            <%= order.trackingNumber %>
                        </td>
                        <td>
                            <%= order.flyerId || 'N/A' %>
                        </td>
                        <td>
                            <%= order.courierType || 'N/A' %>
                        </td>
                        <td>
                            <%= productInfo.date %>
                        </td>
                        <td>
                            <%= productInfo.CustomerName %>
                        </td>
                        <td>
                            <%= productInfo.Address %>
                        </td>
                        <td>
                            <%= productInfo.OrderDetails?.ProductName || 'N/A' %>
                        </td>
                        <td>
                            <%= productInfo.OrderDetails?.Quantity || 'N/A' %>
                        </td>
                        <td>
                            <span class="badge 
                            <%= status.includes('Delivered') ? 'bg-success' :
                            status.includes('Returned') ? 'bg-warning text-dark' :
                            status.includes('On Route') ? 'bg-info' :
                            status.includes('Ready for Pickup') ? 'bg-primary' :
                            'bg-secondary' %>">
                                <%= status %>
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-danger btn-sm delete-order-btn"><i class="bi bi-trash"></i></button>
                            <button class="btn btn-warning btn-sm edit-order-btn" data-bs-toggle="modal"
                                data-bs-target="#orderModal">
                                <i class="bi bi-pencil-square"></i> Edit
                            </button>
                        </td>
                    </tr>
                    <% }) %>
                        <% } %>
    </tbody>
</table>


<!-- Edit Modal -->
<div class="modal fade" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="editOrderForm">
                    <div class="mb-3">
                        <label class="form-label">Tracking Number</label>
                        <input type="text" class="form-control" autofocus id="modalTrackingNumber">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Flyer ID</label>
                        <input type="text" class="form-control" id="modalFlyerId">
                    </div>
                    <div class="mb-3">
                        <label for="modalCourierType" class="form-label">Courier Type</label>
                        <select class="form-control" id="modalCourierType">
                            <option value="" hidden selected disabled>Select a courier</option>
                            <option value="trax">Trax</option>
                            <option value="daewoo">Daewoo</option>
                            <option value="postex">PostEx</option>
                        </select>
                    </div>


                </form>
                <div id="verify-result" class="mt-3 text-center"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveChangesBtn">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const editButtons = document.querySelectorAll(".edit-order-btn");
        const deleteButtons = document.querySelectorAll(".delete-order-btn");
        const resultContainer = document.getElementById("verify-result");
        const form = document.getElementById("editOrderForm");

        // Edit order button functionality
        editButtons.forEach(btn => {
            btn.addEventListener("click", function () {
                const row = btn.closest("tr");
                document.getElementById("modalTrackingNumber").value = row.dataset.trackingNumber;
                document.getElementById("modalFlyerId").value = row.dataset.flyerId;
                document.getElementById("modalCourierType").value = row.dataset.courierType;
                document.getElementById("saveChangesBtn").setAttribute("data-id", row.dataset.id);
            });
        });

        // Save changes functionality
        document.getElementById("saveChangesBtn").addEventListener("click", async function () {
            const orderId = this.getAttribute("data-id");

            const updatedData = {
                trackingNumber: document.getElementById("modalTrackingNumber").value,
                flyerId: document.getElementById("modalFlyerId").value,
                courierType: document.getElementById("modalCourierType").value,
            };

            try {
                const response = await axios.post(`/order/update-order/${orderId}`, updatedData);

                if (response.data.success) {
                    resultContainer.innerHTML = `<span class="badge bg-success">${response.data.message}</span>`;
                    form.reset();
                    setTimeout(() => location.reload(), 1000);
                } else {
                    resultContainer.innerHTML = `<span class="badge bg-danger">${response.data.message}</span>`;
                }
            } catch (error) {
                console.error(error);
                resultContainer.innerHTML = `<span class="badge bg-danger">${error.response?.data?.message || "Server error"}</span>`;
            }
        });

        // Delete order button functionality
        document.querySelectorAll('.delete-order-btn').forEach((button) => {
            button.addEventListener('click', async (e) => {
                const row = e.target.closest('tr');
                const orderId = row.getAttribute('data-id');

                // console.log('Deleting order with ID:', orderId);

                try {
                    const response = await axios.delete(`/order/delete-order/${orderId}`);

                    if (response.data.success) {
                        row.remove();
                    } else {
                        console.log('Error deleting order:', response.data.message);
                    }
                } catch (error) {
                    console.error(error);
                    resultContainer.innerHTML = `<span class="badge bg-danger">${error.response?.data?.message || "Server error"}</span>`;
                }
            });
        });
    });
</script>