<div class="d-flex justify-content-between align-items-center mb-3">
  <h4>Order Details</h4>
  <div>
    <input type="text" id="searchInput" class="form-control d-inline-block" placeholder="Search..."
      style="width: 200px" />
    <button class="btn btn-primary ms-2" onclick="exportTableToCSV('orders.csv')">
      <i class="bi bi-download"></i> Export
    </button>
  </div>
</div>
<!-- changes -->
<!-- changes -->
<!-- Order Table -->
<table class="table table-hover table-bordered order-table">
  <thead class="table-dark">
    <tr>
      <th hidden>id</th>
      <th style="width: 50px">#</th>
      <th style="width: 150px">Tracking Number</th>
      <th style="width: 120px">Flyer ID</th>
      <th style="width: 100px">Courier Type</th>
      <th style="width: 120px">Date</th>
      <th style="width: 150px">Customer Name</th>
      <th style="width: 200px">Address</th>
      <th style="width: 200px">Product Name</th>
      <th style="width: 100px">Quantity</th>
      <th style="width: 300px">Transaction Status</th>
      <th style="width: 100px">Actions</th>
    </tr>
  </thead>
  <tbody id="orderTable">
    <% if (trackingData.length===0) { %>
      <tr>
        <td colspan="6" class="text-center">No orders found</td>
      </tr>
      <% } else { %>
        <% trackingData.forEach((order, index)=> {
          let status = 'N/A';
          if (order.courierType.toLowerCase() === 'postex') {
          status = order.trackingResponse?.status || 'N/A';
          } else if (order.courierType.toLowerCase() === 'daewoo' || order.courierType.toLowerCase() ===
          'trax') {
          status = order.trackingResponse?.status || 'N/A';
          }
          const productInfo = order.productInfo || {};
          %>
          <tr data-id="<%= order._id %>" data-tracking-number="<%= order.trackingNumber %>"
            data-flyer-id="<%= order.flyerId || 'N/A' %>" data-courier-type="<%= order.courierType || 'N/A' %>"
            data-status="<%= status %>">
            <td>
              <%= index + 1 %>
            </td>
            <td>
              <%= order.trackingNumber %>
            </td>
            <td>
              <%= order.flyerId || 'N/A' %>
            </td>
            <td>
              <%= order.courierType || 'N/A' %>
            </td>
            <td>
              <%= productInfo.date %>
            </td>
            <td data-full-text="<%= productInfo.CustomerName %>">
              <%= productInfo.CustomerName %>
            </td>
            <td data-tooltip="<%= productInfo.Address %>">
              <%= productInfo.Address %>
            </td>
            <td data-tooltip="<%= productInfo.OrderDetails?.ProductName || 'N/A' %>">
              <%= productInfo.OrderDetails?.ProductName || 'N/A' %>
            </td>
            <td>
              <%= productInfo.OrderDetails?.Quantity || 'N/A' %>
            </td>
            <td>
              <span class="badge 
                            <%= status.includes('Delivered') ? 'bg-success' :
                            status.includes('Returned') ? 'bg-warning text-dark' :
                            status.includes('On Route') ? 'bg-info' :
                            status.includes('Ready for Pickup') ? 'bg-primary' :
                            'bg-secondary' %>">
                <%= status %>
              </span>
            </td>
            <td>
              <button class="btn btn-danger btn-sm delete-order-btn"><i class="bi bi-trash"></i></button>
              <button class="btn btn-warning btn-sm edit-order-btn" data-bs-toggle="modal" data-bs-target="#orderModal">
                <i class="bi bi-pencil-square"></i> Edit
              </button>
            </td>
          </tr>
          <% }) %>
            <% } %>
  </tbody>
</table>

<style>
  .order-table {
    table-layout: fixed;
    width: 100%;
    min-width: 1440px;
  }

  .order-table th:not(:last-child),
  .order-table td:not(:last-child) {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .order-table th:last-child,
  .order-table td:last-child {
    white-space: nowrap;
    overflow: visible;
  }
</style>

<div class="d-flex justify-content-between align-items-center mt-3">
  <div class="text-muted">
    Showing <%= (pagination.currentPage - 1) * pagination.limit + 1 %> to <%= Math.min(pagination.currentPage *
        pagination.limit, pagination.totalOrders) %> of <%= pagination.totalOrders %> entries
  </div>
  <nav aria-label="Page navigation">
    <ul class="pagination mb-0">
      <li class="page-item <%= pagination.currentPage === 1 ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= pagination.currentPage - 1 %>" aria-label="Previous">
          <span aria-hidden="true">&laquo;</span>
        </a>
      </li>
      <% for(let i=1; i <=pagination.totalPages; i++) { %>
        <li class="page-item <%= pagination.currentPage === i ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %>">
            <%= i %>
          </a>
        </li>
        <% } %>
          <li class="page-item <%= pagination.currentPage === pagination.totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="?page=<%= pagination.currentPage + 1 %>" aria-label="Next">
              <span aria-hidden="true">&raquo;</span>
            </a>
          </li>
    </ul>
  </nav>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Edit Order</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="editOrderForm">
          <div class="mb-3">
            <label class="form-label">Tracking Number</label>
            <input type="text" class="form-control" autofocus id="modalTrackingNumber">
          </div>
          <div class="mb-3">
            <label class="form-label">Flyer ID</label>
            <input type="text" class="form-control" id="modalFlyerId">
          </div>
          <div class="mb-3">
            <label for="modalCourierType" class="form-label">Courier Type</label>
            <select class="form-control" id="modalCourierType">
              <option value="" hidden selected disabled>Select a courier</option>
              <option value="trax">Trax</option>
              <option value="daewoo">Daewoo</option>
              <option value="postex">PostEx</option>
            </select>
          </div>


        </form>
        <div id="verify-result" class="mt-3 text-center"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="saveChangesBtn">Save Changes</button>
      </div>
    </div>
  </div>
</div>

<!-- Scripts -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const editButtons = document.querySelectorAll(".edit-order-btn");
    const deleteButtons = document.querySelectorAll(".delete-order-btn");
    const resultContainer = document.getElementById("verify-result");
    const form = document.getElementById("editOrderForm");

    // Edit order button functionality
    editButtons.forEach(btn => {
      btn.addEventListener("click", function () {
        const row = btn.closest("tr");
        const orderId = row.dataset.id;
        const trackingNumber = row.dataset.trackingNumber;
        const flyerId = row.dataset.flyerId;
        const courierType = row.dataset.courierType;

        // Populate modal with existing data
        document.getElementById("modalTrackingNumber").value = trackingNumber;
        document.getElementById("modalFlyerId").value = flyerId;
        document.getElementById("modalCourierType").value = courierType.toLowerCase();
        document.getElementById("saveChangesBtn").setAttribute("data-id", orderId);
      });
    });

    // Save changes functionality
    document.getElementById("saveChangesBtn").addEventListener("click", async function () {
      const orderId = this.getAttribute("data-id");

      const updatedData = {
        _id: orderId,
        trackingNumber: document.getElementById("modalTrackingNumber").value,
        flyerId: document.getElementById("modalFlyerId").value,
        courierType: document.getElementById("modalCourierType").value,
      };

      try {
        const response = await axios.post(
          `/order/update-order/${orderId}`,
          updatedData
        );

        if (response.data.success) {
          resultContainer.innerHTML = `<span class="badge bg-success">${response.data.message}</span>`;
          setTimeout(() => location.reload(), 1000);
        } else {
          resultContainer.innerHTML = `<span class="badge bg-danger">${response.data.message}</span>`;
        }
      } catch (error) {
        console.error(error);
        resultContainer.innerHTML = `<span class="badge bg-danger">${error.response?.data?.message || "Server error"}</span>`;
      }
    });
    // changes
    // Delete order button functionality
    document.querySelectorAll('.delete-order-btn').forEach((button) => {
      button.addEventListener('click', async (e) => {
        const row = e.target.closest('tr');
        const orderId = row.getAttribute('data-id');

        // Simple confirmation dialog
        if (confirm('Are you sure you want to delete this order?')) {
          try {
            const response = await axios.delete(`/order/delete-order/${orderId}`);

            if (response.data.success) {
              // Show success message
              const successMessage = document.createElement('div');
              successMessage.className = 'alert alert-success alert-dismissible fade show';
              successMessage.innerHTML = `
                ${response.data.message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              `;
              document.querySelector('.d-flex.justify-content-between.align-items-center.mb-3').appendChild(successMessage);

              // Remove the row with animation
              row.style.transition = 'opacity 0.5s ease';
              row.style.opacity = '0';
              setTimeout(() => {
                row.remove();
              }, 500);
            } else {
              alert(response.data.message);
              console.log('Error deleting order:', response.data.message);
            }
          } catch (error) {
            console.error(error);
            resultContainer.innerHTML = `<span class="badge bg-danger">${error.response?.data?.message || "Server error"}</span>`;
          }
        }
      });
    });



    // Preserve search parameter when navigating pages
    document.querySelectorAll('.pagination .page-link').forEach(link => {
      link.addEventListener('click', function (e) {
        const searchInput = document.getElementById('searchInput');
        if (searchInput.value) {
          e.preventDefault();
          const url = new URL(this.href);
          url.searchParams.set('search', searchInput.value);
          window.location.href = url.toString();
        }
      });
    });
  });
</script>