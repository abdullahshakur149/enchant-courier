<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0"><%= title %></h4>

  <div class="d-flex align-items-center">
    <input type="text" id="searchInput" class="form-control" placeholder="Search..." style="width: 200px;" />

    <button class="btn btn-primary ms-2" onclick="exportTableToCSV('<%= exportFileName %>')">
      <i class="bi bi-download"></i> Export
    </button>
  </div>
</div>

<!-- Order  -->
<div class="table-responsive-container">
  <table class="table table-hover table-bordered">
    <thead class="table-dark">
      <tr>
        <th hidden>id</th>
        <th>#</th>
        <th>Tracking</th>
        <th>Status</th>
        <th>Flyer ID</th>
        <th>Courier</th>
        <th>Date</th>
        <th>Customer</th>
        <th>Address</th>
        <th>Product</th>
        <th>Quantity</th>
        <th>Price</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody id="orderTable">
      <% if (trackingData.length === 0) { %>
      <tr>
        <td colspan="13" class="text-center">No orders found</td>
      </tr>
      <% } else { %>
      <% trackingData.forEach((order, index) => { 
            let trackingUrl = '';
            const couriertype = (order.courierType || '').toLowerCase();
            if (couriertype === 'trax') {
              trackingUrl = `https://sonic.pk/tracking?tracking_number=${order.trackingNumber}`;
            } else if (couriertype === 'postex') {
              trackingUrl = `https://postex.pk/tracking?cn=${order.trackingNumber}`;
            } else if (couriertype === 'daewoo') {
              trackingUrl = `https://fastex.appsbymoose.com/track/${order.trackingNumber}`;
            }
        %>
      <tr data-id="<%= order._id %>" data-tracking-number="<%= order.trackingNumber %>" data-flyer-id="<%= order.flyerId || 'N/A' %>" data-courier-type="<%= order.courierType || 'N/A' %>" data-status="<%= order.status %>">

        <td><%= index + 1 %></td>

        <td>
          <a href="<%= trackingUrl %>" target="_blank"><%= order.trackingNumber %></a>
        </td>

        <td>
          <span class="inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800 cursor-pointer" onclick="showTrackingHistory('<%= order._id %>', '<%= JSON.stringify(order.rawJson || {}) %>', '<%= JSON.stringify(order) %>')">
            <%= order.status || 'Not Available' %>
          </span>
        </td>

        <td><%= order.flyerId || 'N/A' %></td>
        <td><%= order.courierType || 'N/A' %></td>
        <td><%= formatDate(order.productInfo?.date) %></td>

        <td data-full-text="<%= order.customer_name || order.productInfo?.CustomerName %>">
          <%= order.customer_name || order.productInfo?.CustomerName || 'N/A' %>
        </td>

        <td data-tooltip="<%= order.address || order.productInfo?.Address %>">
          <%= order.address || order.productInfo?.Address || 'N/A' %>
        </td>

        <td data-tooltip="<%= order.productInfo?.OrderDetails?.ProductName || 'N/A' %>">
          <%= order.productInfo?.OrderDetails?.ProductName || 'N/A' %>
        </td>

        <td><%= order.productInfo?.OrderDetails?.Quantity || 'N/A' %></td>
        <td><%= order.invoicePayment || 'N/A' %></td>

        <td>
          <button class="btn btn-danger btn-sm delete-order-btn mb-2">
            <i class="bi bi-trash"></i>
          </button>
          <button class="btn btn-warning btn-sm edit-order-btn" data-bs-toggle="modal" data-bs-target="#orderModal">
            <i class="bi bi-pencil-square"></i>
          </button>
        </td>
      </tr>
      <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<div class="d-flex justify-content-between align-items-center mt-3">
  <div class="text-muted">
    Showing
    <%= (pagination.currentPage - 1) * pagination.limit + 1 %>
    to
    <%= Math.min(pagination.currentPage * pagination.limit, pagination.totalOrders) %>
    of
    <%= pagination.totalOrders %> entries
  </div>

  <nav aria-label="Page navigation">
    <ul class="pagination mb-0">

      <!-- Previous Button -->
      <li class="page-item <%= pagination.currentPage === 1 ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= pagination.currentPage - 1 %>" aria-label="Previous">
          <span aria-hidden="true">&laquo;</span>
        </a>
      </li>

      <!-- Page Numbers -->
      <% for (let i = 1; i <= pagination.totalPages; i++) { %>
      <li class="page-item <%= pagination.currentPage === i ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>"><%= i %></a>
      </li>
      <% } %>

      <!-- Next Button -->
      <li class="page-item <%= pagination.currentPage === pagination.totalPages ? 'disabled' : '' %>">
        <a class="page-link" href="?page=<%= pagination.currentPage + 1 %>" aria-label="Next">
          <span aria-hidden="true">&raquo;</span>
        </a>
      </li>

    </ul>
  </nav>
</div>


<!-- Edit Modal -->
<div class="modal fade" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Edit Order</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="editOrderForm">
          <div class="mb-3">
            <label class="form-label">Tracking Number</label>
            <input type="text" class="form-control" autofocus id="modalTrackingNumber">
          </div>
          <div class="mb-3">
            <label class="form-label">Flyer ID</label>
            <input type="text" class="form-control" id="modalFlyerId">
          </div>
          <div class="mb-3">
            <label for="modalCourierType" class="form-label">Courier Type</label>
            <select class="form-control" id="modalCourierType">
              <option value="" hidden selected disabled>Select a courier</option>
              <option value="trax">Trax</option>
              <option value="daewoo">Daewoo</option>
              <option value="postex">PostEx</option>
            </select>
          </div>
        </form>
        <div id="verify-result" class="mt-3 text-center"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="saveChangesBtn">Save Changes</button>
      </div>
    </div>
  </div>
</div>

<!-- Tracking History Modal -->
<div class="modal fade" id="trackingHistoryModal" tabindex="-1" aria-labelledby="trackingHistoryModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header  text-white">
        <h5 class="modal-title">
          <i class="bi bi-truck me-2"></i>
          Tracking History
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <div class="row">
          <div class="col-md-6">
            <div class="card h-100">
              <div class="card-header bg-light">
                <h6 class="mb-0">
                  <i class="bi bi-info-circle me-2"></i>
                  Order Details
                </h6>
              </div>
              <div class="card-body" id="orderDetails"></div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="card h-100">
              <div class="card-header bg-light">
                <h6 class="mb-0">
                  <i class="bi bi-clock-history me-2"></i>
                  Tracking History
                </h6>
              </div>
              <div class="card-body p-0">
                <div id="trackingHistoryList" class="timeline"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%
function formatDate(dateString) {
  if (!dateString) return 'N/A';

  const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", 
                  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

  // Normalize to format parsable by JS
  const normalized = dateString.replace(/(\d{2})\/(\d{2})\/(\d{4})/, '$2/$1/$3');
  const date = new Date(normalized);

  if (isNaN(date)) return 'Invalid Date';

  const day = date.getDate();
  const suffix = (day % 10 === 1 && day !== 11) ? 'st' :
                 (day % 10 === 2 && day !== 12) ? 'nd' :
                 (day % 10 === 3 && day !== 13) ? 'rd' : 'th';

  return `${day}${suffix} ${months[date.getMonth()]} ${date.getFullYear()}`;
}
%>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const editButtons = document.querySelectorAll(".edit-order-btn");
    const deleteButtons = document.querySelectorAll(".delete-order-btn");
    const resultContainer = document.getElementById("verify-result");
    const form = document.getElementById("editOrderForm");
    const searchInput = document.getElementById("searchInput");

    // Add search functionality
    searchInput.addEventListener("input", function() {
      const searchTerm = this.value.toLowerCase();
      const tableRows = document.querySelectorAll("#orderTable tr:not(.no-results)");
      let hasResults = false;

      tableRows.forEach(row => {
        const trackingNumber = row.querySelector("td:nth-child(2)")?.textContent.toLowerCase() || "";
        const flyerId = row.querySelector("td:nth-child(3)")?.textContent.toLowerCase() || "";
        const courierType = row.querySelector("td:nth-child(4)")?.textContent.toLowerCase() || "";
        const customerName = row.querySelector("td:nth-child(6)")?.textContent.toLowerCase() || "";
        const address = row.querySelector("td:nth-child(7)")?.textContent.toLowerCase() || "";
        const productName = row.querySelector("td:nth-child(8)")?.textContent.toLowerCase() || "";
        const status = row.querySelector("td:nth-child(10) .badge")?.textContent.toLowerCase() || "";

        const matchesSearch =
          trackingNumber.includes(searchTerm) ||
          flyerId.includes(searchTerm) ||
          courierType.includes(searchTerm) ||
          customerName.includes(searchTerm) ||
          address.includes(searchTerm) ||
          productName.includes(searchTerm) ||
          status.includes(searchTerm);

        row.style.display = matchesSearch ? "" : "none";
        if (matchesSearch) hasResults = true;
      });

      // Handle no results found
      let noResultsRow = document.querySelector("#orderTable tr.no-results");
      if (!hasResults) {
        if (!noResultsRow) {
          noResultsRow = document.createElement("tr");
          noResultsRow.className = "no-results";
          noResultsRow.innerHTML = '<td colspan="13" class="text-center">No matching records found</td>';
          document.getElementById("orderTable").appendChild(noResultsRow);
        }
        noResultsRow.style.display = "";
      } else if (noResultsRow) {
        noResultsRow.style.display = "none";
      }
    });

    // Edit order button functionality
    editButtons.forEach(btn => {
      btn.addEventListener("click", function() {
        const row = btn.closest("tr");
        const orderId = row.dataset.id;
        const trackingNumber = row.dataset.trackingNumber;
        const flyerId = row.dataset.flyerId;
        const courierType = row.dataset.courierType;

        // Populate modal with existing data
        document.getElementById("modalTrackingNumber").value = trackingNumber;
        document.getElementById("modalFlyerId").value = flyerId;
        document.getElementById("modalCourierType").value = courierType.toLowerCase();
        document.getElementById("saveChangesBtn").setAttribute("data-id", orderId);
      });
    });

    // Save changes functionality
    document.getElementById("saveChangesBtn").addEventListener("click", async function() {
      const orderId = this.getAttribute("data-id");

      const updatedData = {
        _id: orderId,
        trackingNumber: document.getElementById("modalTrackingNumber").value,
        flyerId: document.getElementById("modalFlyerId").value,
        courierType: document.getElementById("modalCourierType").value,
      };

      try {
        const response = await axios.post(
          `/order/update-order/${orderId}`,
          updatedData
        );

        if (response.data.success) {
          resultContainer.innerHTML = `<span class="badge bg-success">${response.data.message}</span>`;
          setTimeout(() => location.reload(), 1000);
        } else {
          resultContainer.innerHTML = `<span class="badge bg-danger">${response.data.message}</span>`;
        }
      } catch (error) {
        console.error(error);
        resultContainer.innerHTML = `<span class="badge bg-danger">${error.response?.data?.message || "Server error"}</span>`;
      }
    });

    // Delete order button functionality
    document.querySelectorAll('.delete-order-btn').forEach((button) => {
      button.addEventListener('click', async (e) => {
        const row = e.target.closest('tr');
        const orderId = row.getAttribute('data-id');

        // Simple confirmation dialog
        if (confirm('Are you sure you want to delete this order?')) {
          try {
            const response = await axios.delete(`/order/delete-order/${orderId}`);

            if (response.data.success) {
              // Show success message
              const successMessage = document.createElement('div');
              successMessage.className = 'alert alert-success alert-dismissible fade show';
              successMessage.innerHTML = `
                ${response.data.message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
              `;
              document.querySelector('.d-flex.justify-content-between.align-items-center.mb-3').appendChild(successMessage);

              // Remove the row with animation
              row.style.transition = 'opacity 0.5s ease';
              row.style.opacity = '0';
              setTimeout(() => {
                row.remove();
              }, 500);
            } else {
              alert(response.data.message);
              console.log('Error deleting order:', response.data.message);
            }
          } catch (error) {
            console.error(error);
            resultContainer.innerHTML = `<span class="badge bg-danger">${error.response?.data?.message || "Server error"}</span>`;
          }
        }
      });
    });

    // Preserve search parameter when navigating pages
    document.querySelectorAll('.pagination .page-link').forEach(link => {
      link.addEventListener('click', function(e) {
        const searchInput = document.getElementById('searchInput');
        if (searchInput.value) {
          e.preventDefault();
          const url = new URL(this.href);
          url.searchParams.set('search', searchInput.value);
          window.location.href = url.toString();
        }
      });
    });

    // Add scroll detection for the shadow
    const container = document.querySelector('.table-responsive-container');
    container.addEventListener('scroll', function() {
      const isScrolledToEnd = this.scrollLeft + this.clientWidth >= this.scrollWidth - 1;
      this.classList.toggle('scrolled-to-end', isScrolledToEnd);
    });
  });

  function updateStatusRecord(orderId, status) {
    fetch(`/api/orders/${orderId}/status`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          status
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          alert('Status record updated successfully');
          location.reload();
        } else {
          alert('Failed to update status record');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('An error occurred while updating status record');
      });
  }

  function showTrackingHistory(orderId, rawJson, orderData) {
    const modal = new bootstrap.Modal(document.getElementById('trackingHistoryModal'));
    const orderDetailsDiv = document.getElementById('orderDetails');
    const trackingHistoryList = document.getElementById('trackingHistoryList');

    try {
      const data = JSON.parse(rawJson);
      const order = JSON.parse(orderData);
      console.log('Raw JSON:', data);
      console.log('Order Data:', order);

      let orderDetailsHtml = '';
      let historyHtml = '';

      // Handle Trax format
      if (data.details) {
        orderDetailsHtml = `
                    <p>
                        <strong><i class="bi bi-upc me-2"></i>Tracking Number:</strong><br>
                        <span class="text-primary">${data.details.tracking_number || order.trackingNumber || 'N/A'}</span>
                    </p>
                    <p>
                        <strong><i class="bi bi-hash me-2"></i>Order ID:</strong><br>
                        <span>${order.productInfo?.OrderNumber || 'N/A'}</span>
                    </p>
                    <p>
                        <strong><i class="bi bi-calendar me-2"></i>Order Date:</strong><br>
                        <span>${formatDate(order.productInfo?.date) || 'N/A'}</span>
                    </p>
                    <p>
                        <strong><i class="bi bi-calendar-check me-2"></i>Booking Date:</strong><br>
                        <span>${formatDate(data.details.booking_date) || 'N/A'}</span>
                    </p>
                `;

        if (data.details.tracking_history && data.details.tracking_history.length > 0) {
          const sortedHistory = [...data.details.tracking_history].sort((a, b) => {
            const dateA = new Date(a.timestamp * 1000);
            const dateB = new Date(b.timestamp * 1000);
            return dateB - dateA;
          });

          historyHtml = sortedHistory.map(item => `
                        <div class="timeline-item">
                            <div class="timeline-marker"></div>
                            <div class="timeline-content">
                                <h6 class="mb-1">${item.status || 'N/A'}</h6>
                                <p class="mb-1">${item.location || 'N/A'}</p>
                                <small class="text-muted">${formatDateTime(new Date(item.timestamp * 1000))}</small>
                            </div>
                        </div>
                    `).join('');
        }
      }
      // Handle PostEx format
      else if (data.trackingNumber || data.transactionStatusHistory) {
        orderDetailsHtml = `
                    <p>
                        <strong><i class="bi bi-upc me-2"></i>Tracking Number:</strong><br>
                        <span class="text-primary">${data.trackingNumber || order.trackingNumber || 'N/A'}</span>
                    </p>
                    <p>
                        <strong><i class="bi bi-person me-2"></i>Customer Name:</strong><br>
                        <span>${data.customerName || order.customer_name || 'N/A'}</span>
                    </p>
                    <p>
                        <strong><i class="bi bi-geo-alt me-2"></i>Delivery Address:</strong><br>
                        <span>${data.deliveryAddress || order.address || 'N/A'}</span>
                    </p>
                    <p>
                        <strong><i class="bi bi-calendar me-2"></i>Order Date:</strong><br>
                        <span>${formatDate(data.orderPickupDate) || formatDate(order.productInfo?.date) || 'N/A'}</span>
                    </p>
                    <p>
                        <strong><i class="bi bi-box me-2"></i>Order Details:</strong><br>
                        <span>${data.orderDetail || 'N/A'}</span>
                    </p>
                    <p>
                        <strong><i class="bi bi-currency-dollar me-2"></i>Amount:</strong><br>
                        <span>PKR ${data.invoicePayment || 'N/A'}</span>
                    </p>
                `;

        if (data.transactionStatusHistory && data.transactionStatusHistory.length > 0) {
          // Sort tracking history by updatedAt in descending order (newest first)
          const sortedHistory = [...data.transactionStatusHistory].sort((a, b) => {
            const dateA = new Date(a.updatedAt);
            const dateB = new Date(b.updatedAt);
            return dateB - dateA;
          });

          historyHtml = sortedHistory.map(item => {
            const status = item.transactionStatusMessage || 'N/A';
            const timestamp = item.updatedAt;
            const statusCode = item.transactionStatusMessageCode || '';

            return `
                            <div class="timeline-item">
                                <div class="timeline-marker"></div>
                                <div class="timeline-content">
                                    <h6 class="mb-1">${status}</h6>
                                    <p class="mb-1 text-muted">Status Code: ${statusCode}</p>
                                    <small class="text-muted">${formatDateTime(new Date(timestamp))}</small>
                                </div>
                            </div>
                        `;
          }).join('');
        }
      }
      // Fallback to order data if rawJson is empty
      else {
        orderDetailsHtml = `
                    <p>
                        <strong><i class="bi bi-upc me-2"></i>Tracking Number:</strong><br>
                        <span class="text-primary">${order.trackingNumber || 'N/A'}</span>
                    </p>
                    <p>
                        <strong><i class="bi bi-person me-2"></i>Customer Name:</strong><br>
                        <span>${order.customer_name || order.productInfo?.CustomerName || 'N/A'}</span>
                    </p>
                    <p>
                        <strong><i class="bi bi-geo-alt me-2"></i>Delivery Address:</strong><br>
                        <span>${order.address || order.productInfo?.Address || 'N/A'}</span>
                    </p>
                    <p>
                        <strong><i class="bi bi-calendar me-2"></i>Order Date:</strong><br>
                        <span>${formatDate(order.productInfo?.date) || 'N/A'}</span>
                    </p>
                `;
      }

      orderDetailsDiv.innerHTML = orderDetailsHtml || '<p>No order details available</p>';
      trackingHistoryList.innerHTML = historyHtml || '<p>No tracking history available</p>';
      modal.show();
    } catch (error) {
      console.error('Error parsing tracking data:', error);
      console.error('Raw JSON:', rawJson);
      console.error('Raw order data:', orderData);
      orderDetailsDiv.innerHTML = '<p class="text-danger">Error loading tracking data</p>';
      trackingHistoryList.innerHTML = '';
      modal.show();
    }
  }

  // Helper function to format date
  function formatDate(dateString) {
    if (!dateString) return 'N/A';
    try {
      const date = new Date(dateString);
      return date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
      });
    } catch (error) {
      return 'N/A';
    }
  }

  // Helper function to format date and time
  function formatDateTime(date) {
    if (!date || isNaN(date)) return 'N/A';
    try {
      return date.toLocaleString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
        hour12: true
      });
    } catch (error) {
      return 'N/A';
    }
  }
</script>

<!-- change -->