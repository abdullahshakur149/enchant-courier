<% if (title && title.trim() !=="" ) { %>
  <h2 class="mb-4 fw-bold">
    <%= title %>
  </h2>
  <% } %>
    <div id="orders-table-container"></div>
    <div id="pagination-container" class="pagination-container"></div>


    <%- include('./components/trackingModel.ejs') %>


      <%- include('./components/editmodel.ejs') %>

        <%- include('./components/remarksModel.ejs') %>

          <%- include('./components/remarksHistory.ejs') %>



            <!-- Verify Return Modal -->
            <div class="modal fade" id="verifyReturnModal" tabindex="-1" aria-labelledby="verifyReturnModalLabel"
              aria-hidden="true">
              <div class="modal-dialog">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title" id="verifyReturnModalLabel">Verify Return</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>
                  <div class="modal-body">
                    <div class="alert alert-info mb-3">
                      <i class="fas fa-info-circle me-2"></i>
                      Please scan the returned order's tracking number and flyer ID
                    </div>

                    <div id="verifySuccessMsg" class="alert alert-success d-none" role="alert">
                      Return verified successfully!
                    </div>

                    <form id="verifyReturnForm">
                      <div class="mb-3">
                        <label for="verifytrackingNumber" class="form-label">Tracking Number</label>
                        <input type="text" class="form-control" id="verifytrackingNumber" name="verifytrackingNumber"
                          required autofocus>
                      </div>


                      <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary" id="verifyReturnBtn">Verify Return</button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            </div>




            <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
            <script src="/js/orders.js"></script>
            <script type="module">
              document.addEventListener('DOMContentLoaded', function () {
                OrderManager.init('returned');

                const verifyReturnForm = document.getElementById('verifyReturnForm');
                const trackingNumberInput = document.getElementById('verifytrackingNumber');
                const successMsg = document.getElementById('verifySuccessMsg');

                // Focus on tracking number when modal is shown
                document.getElementById('verifyReturnModal').addEventListener('shown.bs.modal', function () {
                  trackingNumberInput.focus();
                });

                // Handle form submission
                verifyReturnForm.addEventListener('submit', async function (e) {
                  e.preventDefault();

                  const trackingNumber = trackingNumberInput.value.trim();

                  if (!trackingNumber) {
                    alert('Tracking Number is required');
                    return;
                  }

                  const data = { trackingNumber };

                  try {
                    const response = await axios.post('/api/orders/verify-return', data, {
                      headers: {
                        'Content-Type': 'application/json'
                      }
                    });

                    if (response.data.success) {
                      verifyReturnForm.reset();
                      OrderManager.fetchOrders();

                      successMsg.classList.remove('d-none');
                      successMsg.textContent = 'Return verified successfully!';

                      setTimeout(() => {
                        successMsg.classList.add('d-none');
                        trackingNumberInput.focus();
                      }, 3000);
                    } else {
                      alert(response.data.message || 'Failed to verify return');
                    }
                  } catch (error) {
                    console.error('Error verifying return:', error);
                    alert(error.response?.data?.message || 'Error verifying return. Please try again later.');
                  }
                });
              });
            </script>