            <!-- FAQs Section -->
            <div class="card mb-4">
                <div class="card-body">
                    <h2 class="h4 mb-3">Frequently Asked Questions</h2>
                    <div class="accordion" id="faqAccordion">
                        <!-- FAQ Item 1 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                    How do I submit a new order?
                                </button>
                            </h3>
                            <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    To submit a new order, go to the Orders page and click the "Add New Order" button. Fill in the required information including tracking number, courier service, and recipient details.
                                </div>
                            </div>
                        </div>

                        <!-- FAQ Item 2 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                    How do I track an order's status?
                                </button>
                            </h3>
                            <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    You can track an order's status by going to the Orders page and using the search functionality. Enter the tracking number to view the current status and delivery details.
                                </div>
                            </div>
                        </div>

                        <!-- FAQ Item 3 -->
                        <div class="accordion-item">
                            <h3 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                    What should I do if an order is marked as returned?
                                </button>
                            </h3>
                            <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    If an order is marked as returned, check the reason for return in the order details. You can then either update the delivery information and resubmit the order or contact the courier service for more information.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

