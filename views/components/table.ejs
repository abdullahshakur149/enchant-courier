<div class="table-responsive rounded shadow-sm bg-white p-3">
    <!-- Search Bar (placeholder for future extension) -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-semibold"><%= typeof title !== 'undefined' ? title : '' %></h5>
        <form class="d-flex" role="search" style="max-width: 300px;">
            <input class="form-control form-control-sm me-2" type="search" placeholder="Search..." aria-label="Search" disabled>
            <button class="btn btn-outline-primary btn-sm" type="submit" disabled><i class="fas fa-search"></i></button>
        </form>
    </div>
    <table class="table align-middle table-hover mb-0">
        <thead class="table-light">
            <tr>
                <% columns.forEach(function(col) { %>
                    <th><%= col %></th>
                <% }); %>
                <% if (typeof actions !== 'undefined' && actions.length > 0) { %>
                    <th>Actions</th>
                <% } %>
            </tr>
        </thead>
        <tbody>
            <% if (rows && rows.length > 0) { %>
                <% rows.forEach(function(row) { %>
                    <tr>
                        <% columns.forEach(function(colKey) { %>
                            <td><%= row[colKey] %></td>
                        <% }); %>
                        <% if (typeof actions !== 'undefined' && actions.length > 0) { %>
                            <td>
                                <% actions.forEach(function(action) { %>
                                    <% if (action === 'view') { %>
                                        <a href="/orders/<%= row.id %>" class="btn btn-sm btn-outline-primary me-1" title="View"><i class="fas fa-eye"></i></a>
                                    <% } else if (action === 'edit') { %>
                                        <a href="/orders/<%= row.id %>/edit" class="btn btn-sm btn-outline-secondary me-1" title="Edit"><i class="fas fa-edit"></i></a>
                                    <% } else if (action === 'delete') { %>
                                        <button class="btn btn-sm btn-outline-danger" title="Delete" data-id="<%= row.id %>"><i class="fas fa-trash"></i></button>
                                    <% } %>
                                <% }); %>
                            </td>
                        <% } %>
                    </tr>
                <% }); %>
            <% } else { %>
                <tr>
                    <td colspan="<%= columns.length + (actions && actions.length > 0 ? 1 : 0) %>" class="text-center text-muted">No data found.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
    <!-- Pagination (placeholder for future extension) -->
    <div class="d-flex justify-content-end mt-3">
        <nav aria-label="Table pagination">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item disabled"><a class="page-link">Prev</a></li>
                <li class="page-item active"><a class="page-link">1</a></li>
                <li class="page-item disabled"><a class="page-link">Next</a></li>
            </ul>
        </nav>
    </div>
</div> 