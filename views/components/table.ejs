<!-- Table Container -->
<div class="table-container">
    <!-- Table Header -->
    <div class="table-header">
        <h5 class="table-title">
            <i class="fas fa-table"></i>
            <%= typeof title !== 'undefined' ? title : '' %>
            <% if (typeof subtitle !== 'undefined' && subtitle) { %>
                <span class="text-muted small ms-2">(<%= subtitle %>)</span>
            <% } %>
        </h5>
        <div class="d-flex align-items-center gap-3">
            <% if (typeof filters !== 'undefined' && filters.length > 0) { %>
                <div class="table-filters">
                    <% filters.forEach(function(filter) { %>
                        <button class="btn btn-sm btn-outline-secondary">
                            <i class="<%= filter.icon %> me-1"></i>
                            <%= filter.label %>
                        </button>
                    <% }); %>
                </div>
            <% } %>
            <div class="table-search">
                <i class="fas fa-search"></i>
                <input class="form-control" type="search" placeholder="Search..." aria-label="Search" disabled>
            </div>
        </div>
    </div>

    <!-- Table Content -->
    <div class="table-responsive">
        <table class="table align-middle table-hover mb-0">
            <thead>
                <tr>
                    <% columns.forEach(function(col) { %>
                        <th>
                            <div class="d-flex align-items-center gap-2">
                                <i class="fas fa-sort"></i>
                                <%= col %>
                            </div>
                        </th>
                    <% }); %>
                    <% if (typeof actions !== 'undefined' && actions.length > 0) { %>
                        <th class="text-end">Actions</th>
                    <% } %>
                </tr>
            </thead>
            <tbody>
                <% if (rows && rows.length > 0) { %>
                    <% rows.forEach(function(row) { %>
                        <tr>
                            <% columns.forEach(function(colKey) { %>
                                <td data-label="<%= colKey %>">
                                    <% if (colKey === 'Status') { %>
                                        <span class="status-badge status-<%= row[colKey].toLowerCase() %>">
                                            <i class="fas fa-circle"></i>
                                            <%= row[colKey] %>
                                        </span>
                                    <% } else if (colKey === 'Remarks') { %>
                                        <span class="remarks-badge">
                                            <i class="fas fa-comment"></i>
                                            <%= row[colKey] %>
                                        </span>
                                    <% } else if (colKey === 'Date') { %>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="far fa-calendar-alt text-muted"></i>
                                            <%= row[colKey] %>
                                        </div>
                                    <% } else if (colKey === 'Amount') { %>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="fas fa-dollar-sign text-success"></i>
                                            <%= row[colKey] %>
                                        </div>
                                    <% } else { %>
                                        <%= row[colKey] %>
                                    <% } %>
                                </td>
                            <% }); %>
                            <% if (typeof actions !== 'undefined' && actions.length > 0) { %>
                                <td class="action-buttons">
                                    <% actions.forEach(function(action) { %>
                                        <% if (action === 'view') { %>
                                            <button class="btn btn-outline-primary" title="View Details">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                        <% } else if (action === 'edit') { %>
                                            <button class="btn btn-outline-secondary" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                        <% } else if (action === 'delete') { %>
                                            <button class="btn btn-outline-danger" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        <% } %>
                                    <% }); %>
                                </td>
                            <% } %>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="<%= columns.length + (actions && actions.length > 0 ? 1 : 0) %>" class="text-center text-muted">
                            <div class="py-5">
                                <i class="fas fa-inbox fa-3x mb-3"></i>
                                <p class="mb-0">No data found</p>
                                <% if (typeof emptyStateMessage !== 'undefined' && emptyStateMessage) { %>
                                    <p class="text-muted small mt-2"><%= emptyStateMessage %></p>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center p-3 border-top">
        <div class="text-muted small">
            <i class="fas fa-info-circle me-1"></i>
            Showing <%= (currentPage - 1) * limit + 1 %> to <%= Math.min(currentPage * limit, totalItems) %> of <%= totalItems %> entries
        </div>
        <nav aria-label="Table pagination">
            <ul class="pagination mb-0">
                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="#" data-page="<%= currentPage - 1 %>">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                </li>
                <% for(let i = 1; i <= totalPages; i++) { %>
                    <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                        <a class="page-link" href="#" data-page="<%= i %>"><%= i %></a>
                    </li>
                <% } %>
                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                    <a class="page-link" href="#" data-page="<%= currentPage + 1 %>">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>