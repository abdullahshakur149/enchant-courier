<script>
    async function updateSystemStatus() {
        try {
            const response = await fetch('/dashboard/system-status');
            const data = await response.json();

            if (data.success) {
                const statusIndicator = document.querySelector('.status-indicator');
                const statusText = document.querySelector('.status-text');

                // Update status indicator
                statusIndicator.className = 'status-indicator';
                statusIndicator.classList.add(data.data.system.status.toLowerCase());

                // Update status text
                statusText.textContent = `System: ${data.data.system.status} | Uptime: ${data.data.system.uptime} | Memory: ${data.data.system.memoryUsage}`;
            }
        } catch (error) {
            console.error('Error fetching system status:', error);
        }
    }

    // Update status immediately and then every 5 minutes
    updateSystemStatus();
    setInterval(updateSystemStatus, 300000);
</script>