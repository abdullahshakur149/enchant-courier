<div class="modal fade" id="editOrderModal" tabindex="-1" aria-labelledby="editOrderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="editOrderModalLabel">
                    <i class="bi bi-pencil-square"></i> Edit Order
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <form id="editOrderForm">

                    <!-- Tracking Number -->
                    <div class="mb-3">
                        <label for="editTrackingNumber" class="form-label">
                            <i class="bi bi-truck"></i> Tracking Number
                        </label>
                        <input type="text" class="form-control" id="editTrackingNumber" required>
                    </div>

                    <!-- Flyer ID -->
                    <div class="mb-3">
                        <label for="editFlyerId" class="form-label">
                            <i class="bi bi-123"></i> Flyer ID
                        </label>
                        <input type="text" class="form-control" id="editFlyerId" required>
                    </div>

                    <!-- Courier Type -->
                    <div class="mb-3">
                        <label for="editCourierType" class="form-label">
                            <i class="bi bi-truck-front"></i> Courier Type
                        </label>
                        <select class="form-control" id="editCourierType" required>
                            <option value="postex">Postex</option>
                            <option value="daewoo">Daewoo</option>
                            <option value="trax">Trax</option>
                        </select>
                    </div>

                    <!-- Submit Button -->
                    <div class="text-end">
                        <button type="button" class="btn btn-primary" id="editOrderSubmitBtn">
                            <i class="bi bi-save"></i> Save Changes
                        </button>
                    </div>

                </form>
            </div>

        </div>
    </div>
</div>